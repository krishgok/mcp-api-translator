{
  "name": "mcp-api-translator",
  "version": "0.1.0",
  "description": "An MCP server that turns OpenAPI / Postman API definitions into runnable MCP servers, making any API discoverable to AI models.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-api-translator": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "node scripts/e2e.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@readme/openapi-parser": "^6.1.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "openapi-types": "^12.1.3",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
