{
  "name": "mcp-api-translator",
  "version": "0.3.0",
  "description": "An MCP server that turns OpenAPI / Postman API definitions into runnable MCP servers, making any API discoverable to AI models.",
  "license": "AGPL-3.0-or-later",
  "author": "krishgok",
  "type": "module",
  "bin": {
    "mcp-api-translator": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "LICENSING.md",
    "NOTICE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "modelcontextprotocol",
    "openapi",
    "swagger",
    "postman",
    "api",
    "codegen",
    "claude",
    "cursor",
    "cline",
    "ai-tools",
    "llm-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krishgok/mcp-api-translator.git"
  },
  "homepage": "https://github.com/krishgok/mcp-api-translator#readme",
  "bugs": {
    "url": "https://github.com/krishgok/mcp-api-translator/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "e2e": "node scripts/e2e.mjs",
    "e2e:python": "node scripts/e2e-python.mjs",
    "smoke:serve": "node scripts/serve-smoke.mjs",
    "smoke:serve:http": "node scripts/serve-http-smoke.mjs",
    "check:docs": "node scripts/check-docs.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@readme/openapi-parser": "^6.1.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "openapi-types": "^12.1.3",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
