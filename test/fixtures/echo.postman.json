{
  "info": {
    "name": "Echo API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}" }]
  },
  "item": [
    {
      "name": "Get Users",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/users?active=true",
          "host": ["{{baseUrl}}"],
          "path": ["users"],
          "query": [{ "key": "active", "value": "true", "description": "only active users" }]
        }
      }
    },
    {
      "name": "Users by id",
      "item": [
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/:userId",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":userId"],
              "variable": [{ "key": "userId", "value": "1", "description": "the user id" }]
            }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"ada\",\"age\":36}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    }
  ]
}
